{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Seiva Portalen design tokens — exported from Figma E3IGevFTtyWGdmy41DDSNH. Spacing & radius scales are multiples of 4px.",

  "color": {
    "primary": {
      "50": { "$value": "#004D33", "$type": "color", "$description": "Deep Shades — shadows, dark backgrounds" },
      "40": { "$value": "#00875A", "$type": "color", "$description": "Dark Shades — text, components needing contrast ≥ 4.5:1" },
      "30": { "$value": "#0ACC8B", "$type": "color", "$description": "Vibrant Shades — illustrations, graphics, contrast ≥ 3:1" },
      "20": { "$value": "#C5E5DB", "$type": "color", "$description": "Deep Tints — dividers, component strokes, non-contrast-compliant" },
      "10": { "$value": "#E1F5EE", "$type": "color", "$description": "Medium Tints — dividers, highlights" },
      "05": { "$value": "#F2FAF7", "$type": "color", "$description": "Light Tints — backgrounds, hover states" }
    },
    "accent": {
      "50": { "$value": "#333980", "$type": "color" },
      "40": { "$value": "#5F68D3", "$type": "color" },
      "30": { "$value": "#848CF0", "$type": "color" },
      "20": { "$value": "#D5D7F2", "$type": "color" },
      "10": { "$value": "#EBECFA", "$type": "color" },
      "05": { "$value": "#F2F3FA", "$type": "color" }
    },
    "neutral": {
      "50": { "$value": "#141414", "$type": "color", "$description": "Pitch-black — body text, titles, shadows" },
      "40": { "$value": "#424242", "$type": "color", "$description": "Dark Gray — disabled text, contrast ≥ 4.5:1" },
      "30": { "$value": "#888888", "$type": "color", "$description": "Weak Gray — graphics, contrast ≥ 3:1" },
      "20": { "$value": "#E0E0E0", "$type": "color", "$description": "Sunny Gray — dividers, non-contrast-compliant" },
      "10": { "$value": "#F5F5F5", "$type": "color", "$description": "Shining Gray — gray backgrounds" },
      "05": { "$value": "#FFFFFF", "$type": "color", "$description": "Bright — text & backgrounds" }
    },
    "semantic": {
      "$description": "Action tokens point to accent (indigo). Green is reserved for brand identity (logo, active states, hero tints), not for CTAs.",
      "bg":               { "$value": "{color.neutral.05}", "$type": "color" },
      "bg-subtle":        { "$value": "{color.neutral.10}", "$type": "color" },
      "bg-brand-subtle":  { "$value": "{color.primary.05}", "$type": "color" },
      "bg-action-subtle": { "$value": "{color.accent.05}",  "$type": "color" },
      "text":             { "$value": "{color.neutral.50}", "$type": "color" },
      "text-muted":       { "$value": "{color.neutral.40}", "$type": "color" },
      "text-subtle":      { "$value": "{color.neutral.30}", "$type": "color" },
      "text-inverse":     { "$value": "{color.neutral.05}", "$type": "color" },
      "text-brand":       { "$value": "{color.primary.40}", "$type": "color" },
      "text-action":      { "$value": "{color.accent.40}",  "$type": "color" },
      "border":           { "$value": "{color.neutral.20}", "$type": "color" },
      "border-strong":    { "$value": "{color.neutral.30}", "$type": "color" },
      "border-brand":     { "$value": "{color.primary.40}", "$type": "color" },
      "border-action":    { "$value": "{color.accent.40}",  "$type": "color" },
      "action":           { "$value": "{color.accent.40}",  "$type": "color" },
      "action-hover":     { "$value": "{color.accent.50}",  "$type": "color" },
      "action-active":    { "$value": "{color.accent.50}",  "$type": "color" },
      "focus-ring":       { "$value": "{color.accent.30}",  "$type": "color" }
    }
  },

  "font": {
    "family": {
      "display": { "$value": ["Besley", "Georgia", "Times New Roman", "serif"], "$type": "fontFamily", "$description": "Primary — titles, headlines, hero text" },
      "body":    { "$value": ["Archivo", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"], "$type": "fontFamily", "$description": "Secondary — body copy, UI labels" },
      "mono":    { "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    }
  },

  "typography": {
    "title-lg":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.regular}", "fontSize": "96px",  "lineHeight": "1.2", "letterSpacing": "0" }, "$type": "typography" },
    "title-md":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.regular}", "fontSize": "64px",  "lineHeight": "1.2", "letterSpacing": "-1px" }, "$type": "typography" },
    "title-sm":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.regular}", "fontSize": "48px",  "lineHeight": "1.2", "letterSpacing": "0" }, "$type": "typography" },
    "title-xs":  { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.regular}", "fontSize": "32px",  "lineHeight": "1.4", "letterSpacing": "0" }, "$type": "typography" },
    "title-xxs": { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.regular}", "fontSize": "24px",  "lineHeight": "1.2", "letterSpacing": "0" }, "$type": "typography" },

    "body-lg":          { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.regular}",  "fontSize": "24px", "lineHeight": "36px" }, "$type": "typography" },
    "body-lg-semibold": { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.semibold}", "fontSize": "24px", "lineHeight": "36px" }, "$type": "typography" },
    "body-md":          { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.regular}",  "fontSize": "18px", "lineHeight": "27px" }, "$type": "typography" },
    "body-md-semibold": { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.semibold}", "fontSize": "18px", "lineHeight": "27px" }, "$type": "typography" },
    "body-md-bold":     { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.bold}",     "fontSize": "18px", "lineHeight": "27px" }, "$type": "typography" },
    "body-sm":          { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.regular}",  "fontSize": "16px", "lineHeight": "24px" }, "$type": "typography" },
    "body-sm-semibold": { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.semibold}", "fontSize": "16px", "lineHeight": "24px" }, "$type": "typography" },
    "body-sm-bold":     { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.bold}",     "fontSize": "16px", "lineHeight": "24px" }, "$type": "typography" }
  },

  "space": {
    "0":  { "$value": "0",     "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "20px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "7":  { "$value": "28px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "14": { "$value": "56px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" },
    "40": { "$value": "160px", "$type": "dimension" },
    "48": { "$value": "192px", "$type": "dimension" },
    "60": { "$value": "240px", "$type": "dimension" },
    "64": { "$value": "256px", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",      "$type": "dimension" },
    "xs":   { "$value": "4px",    "$type": "dimension" },
    "sm":   { "$value": "8px",    "$type": "dimension" },
    "md":   { "$value": "12px",   "$type": "dimension" },
    "lg":   { "$value": "16px",   "$type": "dimension" },
    "xl":   { "$value": "20px",   "$type": "dimension" },
    "2xl":  { "$value": "24px",   "$type": "dimension" },
    "3xl":  { "$value": "32px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "shadow": {
    "xs":    { "$value": { "color": "#14141414", "offsetX": "0", "offsetY": "1px",  "blur": "2px",  "spread": "0" }, "$type": "shadow" },
    "sm":    { "$value": { "color": "#1414140F", "offsetX": "0", "offsetY": "2px",  "blur": "4px",  "spread": "0" }, "$type": "shadow" },
    "md":    { "$value": { "color": "#14141414", "offsetX": "0", "offsetY": "4px",  "blur": "12px", "spread": "0" }, "$type": "shadow" },
    "lg":    { "$value": { "color": "#1414141A", "offsetX": "0", "offsetY": "12px", "blur": "24px", "spread": "0" }, "$type": "shadow" },
    "xl":    { "$value": { "color": "#1414141F", "offsetX": "0", "offsetY": "24px", "blur": "48px", "spread": "0" }, "$type": "shadow" },
    "focus": { "$value": { "color": "#0ACC8B59", "offsetX": "0", "offsetY": "0",    "blur": "0",    "spread": "3px" }, "$type": "shadow" }
  },

  "motion": {
    "duration": {
      "instant": { "$value": "80ms",  "$type": "duration" },
      "fast":    { "$value": "160ms", "$type": "duration" },
      "base":    { "$value": "240ms", "$type": "duration" },
      "slow":    { "$value": "400ms", "$type": "duration" }
    },
    "easing": {
      "standard":   { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" },
      "emphasized": { "$value": "cubic-bezier(0.3, 0, 0, 1)", "$type": "cubicBezier" }
    }
  },

  "breakpoint": {
    "sm":  { "$value": "640px",  "$type": "dimension" },
    "md":  { "$value": "768px",  "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  }
}
